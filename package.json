{
  "name": "repo-sweep",
  "version": "0.1.0",
  "description": "Batch list, clone, and pull GitLab or GitHub repositories.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "bun run src/repo-sweep.ts",
    "interactive": "bun run src/repo-sweep.ts",
    "list": "bun run src/repo-sweep.ts list",
    "clone": "bun run src/repo-sweep.ts clone",
    "pull": "bun run src/repo-sweep.ts pull",
    "typecheck": "tsc --noEmit",
    "release:notes": "bun run scripts/release-notes.ts",
    "build:bin": "bun run scripts/build.ts",
    "build:bin:current": "bun run scripts/build.ts --current"
  },
  "bin": {
    "repo-sweep": "./src/repo-sweep.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
