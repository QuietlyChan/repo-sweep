GIT_PROVIDER=gitlab
GIT_BASE_URL=http://127.0.0.1/
GIT_API_URL=http://127.0.0.1/api/v4/
GIT_TOKEN=glpat_xxxxxxxxxxxxxxxxxxxx
GIT_TARGET_DIR=./git-projects

# 可选：http 或 ssh。
GIT_CLONE_URL=http

# HTTP clone/pull 使用的 Git 用户名。GitLab 默认 oauth2，GitHub 默认 x-access-token。
GIT_USERNAME=oauth2

# GitHub 示例：
# GIT_PROVIDER=github
# GIT_BASE_URL=https://github.com/
# GIT_API_URL=https://api.github.com/
# GIT_USERNAME=x-access-token

# 可选配置。
GIT_CONCURRENCY=4
GIT_PROGRESS_INTERVAL=15
GIT_SKIP_ARCHIVED=0
GIT_SHOW_TOKEN=0
